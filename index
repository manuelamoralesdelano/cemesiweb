<!DOCTYPE html>
<html lang="es">
<head>
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 40px;
    align-items: flex-end;
    padding: 15px 40px 20px 40px;
    height: 90px;
  }
  
  }
  
  .logo-img {
    height: 70px;
    height: 42px;
    width: auto;
    object-fit: contain;
    margin-bottom: 0px;
    position: relative;
    top: 5px; 
  }
  /* Navigation */
  nav.main-nav {
    flex-grow: 1;
    display: flex;
    justify-content: space-evenly;
    align-items: center;
    align-items: flex-end;
    position: relative;
    top: -5px;
    top: 0;
  }
  nav.main-nav a {
    text-decoration: none;
    color: #6a6a6a;
    font-size: 16px;
    padding-bottom: 2px;
    padding-bottom: 0;
    transition: text-shadow 0.3s ease;
  }
  /* Smooth transition to bold hover effect using text-shadow */
  nav.main-nav a:hover {
    text-shadow: 0.5px 0 0 currentcolor, -0.5px 0 0 currentcolor;
  }
  
  .lang-switch {
    font-size: 15px;
    font-weight: normal; 
    padding-bottom: 5px;
    padding-bottom: 0;
    align-self: flex-end;
    color: #6a6a6a;
    position: relative;
    top: -5px;
    top: 0;
  }
  .lang-switch span {
    cursor: pointer;
  }
  .slide-content {
    background-color: rgba(255, 255, 255, 0.82);
    padding: 25px 60px;
    padding: 8px 20px;
    text-align: center;
    display: inline-block;
  }
  .slide-link {
    font-weight: 400;
    font-size: 33px; 
    color: #6a6a6a;
    font-size: 55px; 
    color: #2b7dbe;
    margin: 0;
    letter-spacing: -0.5px;
    text-decoration: none;
    transition: color 0.3s;
  }
  .slide-link:hover {
    color: #333;
    color: #1a4c74;
    text-decoration: underline;
  }
  .slider-arrows {
  }
  .arrow {
    cursor: pointer;
    font-size: 40px;
    font-size: 25px;
    color: rgba(255, 255, 255, 0.8);
    background: rgba(0,0,0,0.3);
    padding: 10px 20px;
    border-radius: 5px;
    padding: 10px;
    user-select: none;
    pointer-events: auto;
    transition: background 0.3s;
    transition: color 0.3s;
    text-shadow: 0 2px 5px rgba(0,0,0,0.5); /* subtle shadow for visibility */
  }
  .arrow:hover {
    background: rgba(0,0,0,0.6);
    color: white;
  }
.hero-banner {
    flex-grow: 1;
    display: flex;
    justify-content: space-evenly;
    align-items: center;
    align-items: flex-end;
    position: relative;
    top: -5px;
    top: 0;
  }
    .lang-switch { align-self: center; top: 0; }
    
  <header>
    <a href="index.html" class="logo-container" aria-label="CEMESI Inicio" style="text-decoration: none;">
      <img src="https://i.imgur.com/7C1C5rk.png" alt="Logo CEMESI" class="logo-img" style="height: 70px; width: auto;">
      <img src="https://i.imgur.com/7C1C5rk.png" alt="Logo CEMESI" class="logo-img" style="height: 42px; width: auto;">
    </a>
    <nav class="main-nav">
        <a href="nosotros.html" data-translate="nosotros">Nosotros</a>
    <main class="hero">
    <div class="slider">
      <div class="slide active" style="background-image: url('https://i.imgur.com/utSPpvj.jpg');">
      <div class="slide active" style="background-image: url('https://i.imgur.com/2lU10Ig.jpg');">
        <div class="slide-content">
          <img src="https://i.imgur.com/SpJaJBO.png" alt="CEMESI" style="height: 100px;">
        </div>
      </div>
      <div class="slide" style="background-image: url('https://i.imgur.com/2lU10Ig.jpg');">
        <div class="slide-content">
          <a href="servicios.html" class="slide-link">Medicina de Precisión</a>
        </div>
      </div>
    function resetInterval() {
      clearInterval(slideInterval);
      slideInterval = setInterval(nextSlide, 4000);
      slideInterval = setInterval(nextSlide, 12000);
    }
    document.addEventListener('DOMContentLoaded', () => {
      slideInterval = setInterval(nextSlide, 4000);
      slideInterval = setInterval(nextSlide, 12000);
    });
    // Modal Logic
    document.addEventListener('DOMContentLoaded', () => {
      btnEs.addEventListener('click', () => setLang('es'));
      btnEn.addEventListener('click', () => setLang('en'));
      const addressLink = document.getElementById('address-link');
      const mapModal = document.getElementById('mapModal');
      const closeMap = document.getElementById('closeMap');
      addressLink.addEventListener('click', (e) => {
        e.preventDefault();
        mapModal.classList.add('active');
      });
      closeMap.addEventListener('click', () => {
        mapModal.classList.remove('active');
      });
      mapModal.addEventListener('click', (e) => {
        if (e.target === mapModal) {
          mapModal.classList.remove('active');
        }
      });
      
      // Allow escape key to close map
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mapModal.classList.contains('active')) {
          mapModal.classList.remove('active');
        }
      });
    });
  </script>
</body>
</html>
